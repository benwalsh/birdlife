<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- macOS launchd agent: pushes new local detections to the cloud RDS every 5 min,
     while the Mac is the listening station (the Pi uses deploy/birdlife-push.timer).
     Install:   cp deploy/net.culfinbirds.push.plist ~/Library/LaunchAgents/
                launchctl load -w ~/Library/LaunchAgents/net.culfinbirds.push.plist
     Uninstall: launchctl unload -w ~/Library/LaunchAgents/net.culfinbirds.push.plist
     Logs:      /tmp/culfinbirds-push.log -->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>net.culfinbirds.push</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-lc</string>
    <string>cd /Users/benwalsh/code/birdlife &amp;&amp; set -a &amp;&amp; source .env &amp;&amp; set +a &amp;&amp; /opt/homebrew/bin/uv run python listener/push.py</string>
  </array>
  <key>StartInterval</key>
  <integer>300</integer>
  <key>RunAtLoad</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/tmp/culfinbirds-push.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/culfinbirds-push.log</string>
</dict>
</plist>
