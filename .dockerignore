# Context for the cloud image (docker build . at the repo root). Keep it lean but
# KEEP pipeline/assets/illustrations — public/birds symlinks to it and the collage
# presenter reads the masks at runtime. (The ARM validation build uses its own
# deploy/Dockerfile.armcheck.dockerignore.)
.git
.github
.venv
**/__pycache__
**/*.pyc
**/.pytest_cache
**/.DS_Store
node_modules
dashboard/node_modules
dashboard/vendor
dashboard/tmp
dashboard/log
dashboard/storage/*.sqlite3
dashboard/storage/*.sqlite3-*
dashboard/public/vite
dashboard/public/assets
pipeline/assets/references
.sync_cursor
storage/almanac.json
