- content_for :title, "Connemara Birds — Atlas"
- content_for :heading, "Atlas"
- all_scope = (@scope == 'all' ? 'all' : nil)
%section.view#v2{ "aria-label": "Atlas" }
  .atlas-controls
    %nav.atlas-scope{ role: "tablist", "aria-label": "which birds" }
      - { 'heard' => 'heard', 'all' => 'all species' }.each do |key, tip|
        %a{ href: atlas_path(h: current_window, sort: @sort, scope: (key == 'all' ? 'all' : nil)), "aria-current": (@scope == key ? "true" : nil) }= tip
    %nav.atlas-sort{ role: "tablist", "aria-label": "sort atlas" }
      - { 'count' => 'most heard', 'recent' => 'most recent', 'alpha' => 'a → z' }.each do |key, tip|
        %a{ href: atlas_path(h: current_window, sort: key, scope: all_scope), "aria-current": (@sort == key ? "true" : nil) }= tip
  .atlas-grid
    - @species.each do |entry|
      - name = entry.name
      - seen = entry.count.positive?
      %a.bird-card{ class: ("unseen" unless seen), href: species_path(entry.sci_name), "data-sci": entry.sci_name, "data-turbo-frame": "detail" }
        - if (cons = Conservation.status(entry.sci_name))
          %span.cons-dot{ class: cons, title: "#{Conservation.name(entry.sci_name)} — #{Conservation.note(entry.sci_name)}" }
        .stat
          - if seen
            %span.n= number_with_delimiter(entry.count)
            %span.lbl heard
          - else
            %span.lbl.unheard not yet heard
        .img-wrap
          - if (img = bird_illustration(entry.sci_name))
            %img{ src: img, alt: name.en, loading: "lazy" }
        %h3= name.ga || name.en
        %p.sci= name.en
