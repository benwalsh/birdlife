!!!
%html{ lang: "en" }
  %head
    %meta{ charset: "utf-8" }/
    %meta{ name: "viewport", content: "width=device-width, initial-scale=1" }/
    %meta{ name: "station-screen", content: @station_screen }/
    %meta{ name: "station-dwell", content: @station_dwell_seconds }/
    %title Éist · #{@station_screen.titleize}
    = stylesheet_link_tag 'colors'
    :css
      * { box-sizing: border-box; }
      html, body { margin: 0; min-height: 100%; }
      body {
        min-height: 100vh; display: flex; flex-direction: column;
        align-items: center; justify-content: center; gap: 16px;
        padding: 4vmin; background: var(--frame);
        font-family: "Baskerville", "Hoefler Text", "EB Garamond", Georgia, serif;
      }
      .frame {
        padding: 26px; border-radius: 12px; background: #2c2c30;
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.06),
                    inset 0 -3px 8px rgba(0,0,0,0.6), 0 24px 60px rgba(0,0,0,0.65);
      }
      .mat { padding: 10px; border-radius: 3px; background: var(--paper-2); }
      .inky {
        width: 480px; height: 800px; overflow: hidden;
        filter: url(#eink) contrast(1.05) brightness(0.91);
      }
      .spec { font: 10px ui-monospace, Menlo, monospace; letter-spacing: 0.14em; text-transform: uppercase; color: #8a8a90; }

      .station {
        position: relative; width: 480px; height: 800px; overflow: hidden;
        background: var(--paper); color: var(--ink); padding: 34px;
        display: flex; flex-direction: column;
      }
      .station::after {
        content: attr(data-screen); position: absolute; right: 22px; bottom: 18px;
        font: 9px ui-monospace, Menlo, monospace; letter-spacing: 0.16em;
        text-transform: uppercase; color: var(--ink-soft);
      }
      .masthead { text-align: center; flex: 0 0 auto; }
      .wordmark { margin: 0; font-size: 58px; font-weight: 500; line-height: 1; }
      .place { margin: 4px 0 0; font-style: italic; font-size: 20px; }
      .rule { border: 0; border-top: 1px solid var(--ink); margin: 14px 0 0; }
      .kicker {
        margin: 0 0 12px; font: 10px ui-monospace, Menlo, monospace;
        letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-soft);
      }
      .quiet { color: var(--ink-soft); }
      .screen { flex: 1 1 auto; min-height: 0; display: flex; flex-direction: column; }
      .screen--collage .collage-area { flex: 1 1 auto; min-height: 0; margin: 16px 0 8px; display: flex; align-items: center; }
      .collage-area svg { width: 100%; height: auto; display: block; }
      .collage-caption { margin: 0; text-align: center; font-style: italic; font-size: 19px; color: var(--ink-soft); }

      .stat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-top: 24px; }
      .stat { border-top: 1px solid var(--ink); padding-top: 14px; min-height: 120px; }
      .stat .n { display: block; font-size: 58px; line-height: 0.95; font-variant-numeric: tabular-nums; }
      .stat .lbl { display: block; margin-top: 9px; font: 10px ui-monospace, Menlo, monospace; letter-spacing: 0.13em; text-transform: uppercase; color: var(--ink-soft); }
      .periods { list-style: none; margin: 30px 0 0; padding: 0; border-top: 1px solid var(--rule); }
      .periods li { display: flex; justify-content: space-between; padding: 11px 0; border-bottom: 1px solid var(--rule); font-size: 20px; }
      .periods b { font-weight: 500; font-variant-numeric: tabular-nums; }

      .focus-art { flex: 1 1 auto; min-height: 0; display: flex; align-items: center; justify-content: center; margin: 18px 0 10px; }
      .focus-art img { max-width: 100%; max-height: 410px; object-fit: contain; }
      .focus-dot { width: 250px; height: 250px; border-radius: 50%; background: var(--paper-3); }
      .focus-name { margin: 0; text-align: center; font-size: 42px; line-height: 1.05; font-weight: 500; }
      .focus-en { margin: 8px 0 0; text-align: center; font-style: italic; font-size: 22px; color: var(--ink-soft); }
      .focus-meta { display: flex; justify-content: center; gap: 20px; margin-top: 18px; font: 12px ui-monospace, Menlo, monospace; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-soft); }

      .almanac { display: grid; grid-template-columns: 1fr 1fr; gap: 22px; margin-top: 24px; }
      .almanac .tile { min-height: 150px; border-top: 1px solid var(--ink); padding-top: 16px; }
      .almanac .ico { width: 66px; height: 66px; stroke: var(--ink); fill: none; stroke-width: 1.25; }
      .almanac .big { display: block; margin-top: 12px; font-size: 31px; line-height: 1.05; }
      .almanac .lbl { display: block; margin-top: 7px; font: 10px ui-monospace, Menlo, monospace; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-soft); }
      .recent { margin-top: 28px; }
      .recent ul { list-style: none; margin: 0; padding: 0; border-top: 1px solid var(--rule); }
      .recent li { display: flex; justify-content: space-between; align-items: baseline; gap: 20px; padding: 10px 0; border-bottom: 1px solid var(--rule); }
      .recent .rname { font-size: 21px; }
      .recent .rtime { flex: 0 0 auto; font: 11px ui-monospace, Menlo, monospace; color: var(--ink-soft); }
      .empty { flex: 1 1 auto; display: flex; align-items: center; justify-content: center; text-align: center; font-size: 34px; font-style: italic; color: var(--ink-soft); }
  %body
    %svg{ width: 0, height: 0, style: 'position:absolute' }
      %filter#eink
        %feColorMatrix{ type: 'saturate', values: '0.68' }
        %feComponentTransfer
          %feFuncR{ type: 'discrete', tableValues: '0 0.33 0.66 1' }
          %feFuncG{ type: 'discrete', tableValues: '0 0.33 0.66 1' }
          %feFuncB{ type: 'discrete', tableValues: '0 0.33 0.66 1' }
    .frame
      .mat
        .inky
          %main.station{ class: "screen--#{@station_screen}", data: { screen: @station_screen } }
            %header.masthead
              %h1.wordmark Éist
              %p.place Connemara
              %hr.rule/
            - case @station_screen
            - when 'collage'
              %section.screen.screen--collage{ "aria-label": "Bird collage" }
                .collage-area
                  = render partial: 'panel'
                %p.collage-caption
                  - if @collage.species_count.positive?
                    heard around the cottage today
                  - else
                    ag éisteacht…
            - when 'stats'
              %section.screen.screen--stats{ "aria-label": "Station statistics" }
                %p.kicker Today at the listening station
                .stat-grid
                  .stat
                    %span.n= @species_today
                    %span.lbl species today
                  .stat
                    %span.n= number_with_delimiter(@detections_today)
                    %span.lbl detections today
                  .stat
                    %span.n= @species_all_time
                    %span.lbl life list
                  .stat
                    %span.n= number_with_delimiter(@detections_all_time)
                    %span.lbl all detections
                %ul.periods
                  - @periods.each do |label, count|
                    %li
                      %span= label
                      %b= number_with_delimiter(count)
            - when 'focus'
              %section.screen.screen--focus{ "aria-label": "Featured bird" }
                - if @featured
                  - name = @featured.name
                  - moment = station_time(@featured.last_time)
                  .focus-art
                    - if (url = bird_illustration(name.sci))
                      %img{ src: url, alt: name.en }
                    - else
                      .focus-dot
                  %h2.focus-name= name.ga || name.en
                  %p.focus-en= name.en
                  .focus-meta
                    %span= "#{@featured.count} calls"
                    %span= heard_ago(moment)
                    %span= "#{(@featured.confidence * 100).round}%"
                - else
                  .empty Waiting for the first confident bird
            - when 'general'
              %section.screen.screen--general{ "aria-label": "Station almanac" }
                %p.kicker The cottage this morning
                .almanac
                  .tile
                    %svg.ico{ viewBox: '0 0 24 24' }
                      %path{ d: 'M7 18a4 4 0 0 1 0-8 5 5 0 0 1 9.6-1.3A3.6 3.6 0 0 1 17.5 18Z' }
                    %span.big 14°C
                    %span.lbl weather
                  .tile
                    %svg.ico{ viewBox: '0 0 24 24' }
                      %path{ d: 'M16 3a9 9 0 1 0 4 7 7 7 0 0 1-4-7Z' }
                    %span.big= @moon.name
                    %span.lbl moon
                  .tile
                    %svg.ico{ viewBox: '0 0 24 24' }
                      %path{ d: 'M12 21s7-5.2 7-11a7 7 0 0 0-14 0c0 5.8 7 11 7 11Z' }
                      %circle{ cx: 12, cy: 10, r: 2.2 }
                    %span.big Connemara
                    %span.lbl station
                  .tile
                    %svg.ico{ viewBox: '0 0 24 24' }
                      %path{ d: 'M4 17h16M6 13c2.2-3.8 4.1-5.7 6-5.7s3.8 1.9 6 5.7' }
                    %span.big Dawn
                    %span.lbl next chorus
                .recent
                  %p.kicker Recently heard
                  %ul
                    - @recent.first(4).each do |item|
                      - name = item.name
                      - moment = station_time(item.last_time)
                      %li
                        %span.rname= name.ga || name.en
                        %span.rtime= moment&.strftime('%H:%M')
    %span.spec= "Inky Impression 7.3″ · #{@station_screen} · #{@station_dwell_seconds / 60} min dwell"
