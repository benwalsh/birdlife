-# A 2-way toggle for one thing your daily email can cover: in the email, or off.
-# (Immediate "alerts" are out of scope for now — the daily email is the one channel,
-# so there's no "Now".) "In email" posts the digest cadence; "Off" removes it.
- on = current.present? && current != "off"
= form_with url: subscription_cadence_path, method: :post, class: "acct-cadence", data: { turbo: false } do
  = hidden_field_tag :alert_type, alert_type
  = button_tag "In email", type: :submit, name: "cadence", value: "digest",
    class: "acct-seg#{' is-on' if on}", "aria-pressed": on
  = button_tag "Off", type: :submit, name: "cadence", value: "off",
    class: "acct-seg#{' is-on' unless on}", "aria-pressed": !on
