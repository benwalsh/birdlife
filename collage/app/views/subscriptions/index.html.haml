- content_for(:title) { "Account · Éin Chulfin" }

.acct
  %header.acct-top
    %a.acct-home{ href: "/" } ← Éin Chulfin
    %h1.acct-h1 Account

  %section.acct-me
    - if current_user.avatar_url.present?
      %img.acct-avatar{ src: current_user.avatar_url, alt: current_user.display_name, referrerpolicy: "no-referrer" }
    - else
      %span.acct-avatar.acct-avatar-initial= current_user.display_name.to_s.strip.first&.upcase
    .acct-me-id
      %span.acct-me-name= current_user.display_name
      - if current_user.email.present? && current_user.email != current_user.display_name
        %span.acct-me-email= current_user.email
    .acct-me-actions
      - if current_user.admin?
        %a.acct-btn{ href: admin_path } Admin
      = button_to "Sign out", logout_path, method: :delete, class: "acct-btn acct-remove"

  %section.acct-sec
    %h2.acct-h2 Alert delivery
    %p.acct-lead Choose how the cottage tells you what it hears. “Digest” gathers a day’s birds into one morning email; “Off” stays silent.
    %ul.acct-rules
      - SubscriptionsController::STANDING_RULES.each do |type, label|
        %li.acct-rule
          %span.acct-rule-label= label
          = render "cadence", alert_type: type, current: @rule_cadence[type]
      %li.acct-rule
        %span.acct-rule-label Birds you follow
        = render "cadence", alert_type: "species", current: @follow_cadence

  %section.acct-sec
    %h2.acct-h2 Daily letter
    %p.acct-lead A short note about the cottage's day, once each morning — even on a day none of the birds you follow turn up.
    %ul.acct-rules
      %li.acct-rule
        %span.acct-rule-label Send me the daily letter
        = form_with url: subscription_cadence_path, method: :post, class: "acct-cadence", data: { turbo: false } do
          = hidden_field_tag :alert_type, "roundup"
          = button_tag "On", type: :submit, name: "cadence", value: "digest",
            class: "acct-seg#{' is-on' if @roundup}", "aria-pressed": @roundup
          = button_tag "Off", type: :submit, name: "cadence", value: "off",
            class: "acct-seg#{' is-on' unless @roundup}", "aria-pressed": !@roundup

  %section.acct-sec
    %h2.acct-h2 Species you're following
    %p.acct-lead Follow a bird here or by ticking it on the site; how you're told is set above.
    - if @follows.any?
      %ul.acct-list
        - @follows.each do |sub|
          - name = BirdName.lookup(sub.sci_name)
          %li.acct-item
            %span.acct-name= name.en
            - if name.ga
              %span.acct-ga= name.ga
            = button_to "Unfollow", subscription_path(sub), method: :delete, class: "acct-btn acct-remove"
    - else
      %p.acct-empty You're not following any species yet.

    = form_with url: subscriptions_path, method: :post, class: "acct-add" do
      = hidden_field_tag "subscription[alert_type]", "species"
      = select_tag "subscription[sci_name]",
        options_for_select(@species.map { |sci, n| [n.ga ? "#{n.en} · #{n.ga}" : n.en, sci] }),
        prompt: "Choose a species…", class: "acct-select"
      = submit_tag "Follow", class: "acct-btn acct-add-btn"
