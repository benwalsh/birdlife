- content_for(:title) { "Account · Éist" }

.acct
  %header.acct-top
    %a.acct-home{ href: "/" } ← Éist
    %h1.acct-h1 Account

  %section.acct-me
    - if current_user.avatar_url.present?
      %img.acct-avatar{ src: current_user.avatar_url, alt: current_user.display_name, referrerpolicy: "no-referrer" }
    - else
      %span.acct-avatar.acct-avatar-initial= current_user.display_name.to_s.strip.first&.upcase
    .acct-me-id
      %span.acct-me-name= current_user.display_name
      - if current_user.email.present? && current_user.email != current_user.display_name
        %span.acct-me-email= current_user.email
    - if current_user.admin?
      %a.acct-link.acct-me-admin{ href: admin_path } Admin

  %section.acct-sec
    %h2.acct-h2 Your daily email
    %p.acct-lead One email a day. Choose what it covers; “Off” leaves it out.
    %ul.acct-rules
      %li.acct-rule
        %span.acct-rule-label The daily letter
        = render "cadence", alert_type: "roundup", current: (@roundup ? "digest" : "off")
      %li.acct-rule
        %span.acct-rule-label Birds you follow
        = render "cadence", alert_type: "species", current: @follow_cadence

  %section.acct-sec
    %h2.acct-h2 Breaking news
    %p.acct-lead A rarity or a first-ever sighting, emailed the moment it turns up — not held for the daily letter.
    %ul.acct-rules
      %li.acct-rule
        %span.acct-rule-label Rarities & first sightings
        = render "cadence", alert_type: "breaking", current: (@breaking ? "immediate" : "off"),
          on_value: "immediate", on_label: "On"

  %section.acct-sec
    %h2.acct-h2 Species you're following
    %p.acct-lead Follow a bird here or by ticking it on the site; what's in your email is set above.
    - if @follows.any?
      %ul.acct-list
        - @follows.each do |sub|
          - name = BirdName.lookup(sub.sci_name)
          %li.acct-item
            %span.acct-name= name.en
            - if name.ga
              %span.acct-ga= name.ga
            = button_to "Unfollow", subscription_path(sub), method: :delete, class: "acct-btn acct-remove"
    - else
      %p.acct-empty You're not following any species yet.

    = form_with url: subscriptions_path, method: :post, class: "acct-add" do
      = hidden_field_tag "subscription[alert_type]", "species"
      = select_tag "subscription[sci_name]",
        options_for_select(@species.map { |sci, n| [n.ga ? "#{n.en} · #{n.ga}" : n.en, sci] }),
        prompt: "Choose a species…", class: "acct-select"
      = submit_tag "Follow", class: "acct-btn acct-add-btn"

  %footer.acct-foot
    = button_to "Sign out", logout_path, method: :delete, class: "acct-link"
